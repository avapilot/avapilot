# AvaPilot — set one of these API keys, then run the server.
# Provider is auto-detected from whichever key you set.

# Option A: Anthropic (default)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option B: OpenAI
# OPENAI_API_KEY=your_openai_api_key_here

# Optional overrides
# LLM_PROVIDER=anthropic          # Force provider (anthropic | openai)
# CHAT_MODEL=claude-sonnet-4-5-20250929   # Override chat model
# TRANSACTION_MODEL=claude-sonnet-4-5-20250929
# ANALYSIS_MODEL=claude-sonnet-4-5-20250929
# VERBOSE_LOGGING=true
